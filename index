<!-- ========================= -->
<!-- BARRA DINÁMICA -->
<!-- ========================= -->

<script>

const raised = 680;
const goal = 1000;

const percent = (raised / goal) * 100;

document.getElementById("raisedAmount").innerText =
`$${raised}`;

document.getElementById("progressFill").style.width =
`${Math.min(percent,100)}%`;

</script>

</body>
</html>
