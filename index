<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Apoya a Churonini 💖</title>

<!-- Fuente -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

<!-- PayPal SDK -->
<script src="https://www.paypal.com/sdk/js?client-id=sb&components=hosted-buttons&disable-funding=venmo&currency=USD"></script>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Inter',sans-serif;
    background:linear-gradient(135deg,#0f0c1f 0%,#1b1230 100%);
    color:white;
    min-height:100vh;
    padding:20px;
}

.container{
    max-width:1000px;
    margin:auto;
}

.card{
    background:rgba(25,25,40,0.85);
    backdrop-filter:blur(10px);
    border-radius:30px;
    padding:35px;
    box-shadow:0 20px 60px rgba(0,0,0,0.4);
    border:1px solid rgba(255,255,255,0.08);
}

/* Badge TikTok */
.badge{
    display:inline-flex;
    align-items:center;
    gap:8px;
    background:black;
    padding:10px 18px;
    border-radius:100px;
    font-weight:700;
    margin-bottom:25px;
}

.badge i{
    color:#25F4EE;
}

/* Perfil */
.profile{
    text-align:center;
    margin-bottom:25px;
}

.profile img{
    width:150px;
    height:150px;
    border-radius:50%;
    object-fit:cover;
    border:5px solid #ff7eb3;
    box-shadow:0 0 25px rgba(255,126,179,0.5);
    margin-bottom:15px;
}

.profile h1{
    font-size:2.8rem;
    font-weight:800;
    background:linear-gradient(135deg,#FFE6F0,#FFA0C0);
    -webkit-background-clip:text;
    color:transparent;
    margin-bottom:10px;
}

.profile p{
    max-width:750px;
    margin:auto;
    color:#ddd;
    font-size:1.05rem;
    line-height:1.7;
}

/* Meta */
.goal-container{
    background:rgba(0,0,0,0.35);
    border-radius:22px;
    padding:22px;
    margin-top:30px;
}

.goal-stats{
    display:flex;
    justify-content:space-between;
    gap:10px;
    margin-bottom:12px;
    font-weight:700;
    flex-wrap:wrap;
}

.progress-bar{
    width:100%;
    height:16px;
    background:#2d2d44;
    border-radius:100px;
    overflow:hidden;
}

.progress-fill{
    height:100%;
    width:68%;
    background:linear-gradient(90deg,#ff6a88,#ff99ac);
    border-radius:100px;
}

.goal-text{
    margin-top:10px;
    font-size:0.95rem;
    color:#ccc;
}

/* Video */
.video-preview{
    margin-top:35px;
    border-radius:25px;
    overflow:hidden;
    background:#111;
    text-align:center;
}

.video-preview img{
    width:100%;
    display:block;
}

.video-preview p{
    padding:14px;
}

/* Donaciones */
.donation-section{
    text-align:center;
    margin-top:40px;
}

.donation-section h2{
    margin-bottom:10px;
    font-size:2rem;
}

.donation-section p{
    color:#ccc;
    margin-bottom:25px;
}

/* Actualizaciones */
.updates{
    margin-top:40px;
}

.updates h3{
    margin-bottom:20px;
    font-size:1.5rem;
}

.update{
    background:rgba(255,255,255,0.05);
    padding:18px;
    border-radius:18px;
    margin-bottom:15px;
}

.update strong{
    display:block;
    margin-bottom:8px;
    color:#ffb3ca;
}

/* Redes */
.socials{
    margin-top:40px;
    text-align:center;
}

.socials a{
    color:white;
    font-size:2rem;
    margin:0 10px;
    transition:0.3s;
}

.socials a:hover{
    color:#ff7eb3;
    transform:scale(1.1);
}

/* Footer */
footer{
    text-align:center;
    margin-top:30px;
    opacity:0.7;
    font-size:0.9rem;
}

@media(max-width:768px){

    .card{
        padding:22px;
    }

    .profile h1{
        font-size:2rem;
    }

    .profile img{
        width:120px;
        height:120px;
    }

    .goal-stats{
        flex-direction:column;
    }
}
</style>
</head>

<body>

<div class="container">

    <div class="card">

        <!-- Badge -->
        <div class="badge">
            <i class="fab fa-tiktok"></i>
            @churonini
        </div>

        <!-- Perfil -->
        <div class="profile">

            <!-- FOTO DE PERFIL -->
            <!-- CAMBIA ESTA URL POR LA FOTO REAL -->
            <img src="https://placehold.co/300x300/png?text=Churonini" alt="Foto de perfil de Churonini">

            <h1>¡Apoya a Churonini! 💖</h1>

            <p>
                Somos un emprendimiento familiar creando vídeos divertidos,
                blogs y contenido creativo protagonizado por una niña de 8 años.
                Tu apoyo nos ayuda a mejorar cámaras, luces, micrófonos y seguir
                creando contenido bonito y entretenido para toda la comunidad.
            </p>

        </div>

        <!-- Barra -->
        <div class="goal-container">

            <div class="goal-stats">
                <span>
                    <i class="fas fa-hand-holding-heart"></i>
                    Recaudado:
                    <strong id="raisedAmount">$680</strong>
                </span>

                <span>
                    Meta:
                    <strong>$1000</strong>
                </span>
            </div>

            <div class="progress-bar">
                <div class="progress-fill" id="progressFill"></div>
            </div>

            <div class="goal-text">
                <i class="fas fa-users"></i>
                47 personas ya apoyaron esta campaña ❤️
            </div>

        </div>

        <!-- Video / Banner -->
        <div class="video-preview">

            <!-- CAMBIA ESTA IMAGEN -->
            <img src="https://placehold.co/1200x500/1E1E2F/FFA0C0?text=Contenido+de+Churonini" alt="Contenido Churonini">

            <p>
                ✨ Gracias por apoyar este sueño ✨
            </p>

        </div>

        <!-- PayPal -->
        <div class="donation-section">

            <h2>Haz una donación</h2>

            <p>
                Cada aporte ayuda muchísimo 💕
            </p>

            <!-- BOTÓN PAYPAL -->
            <div id="paypal-container-N4TKCWT46D6WJ"></div>

        </div>

        <!-- Updates -->
        <div class="updates">

            <h3>
                <i class="fas fa-newspaper"></i>
                Últimas actualizaciones
            </h3>

            <div class="update">
                <strong>
                    <i class="far fa-calendar-alt"></i>
                    20 de mayo, 2026
                </strong>

                <p>
                    Gracias al apoyo recibido ya mejoramos el audio de los videos 🎤
                </p>
            </div>

            <div class="update">
                <strong>
                    <i class="far fa-calendar-alt"></i>
                    10 de mayo, 2026
                </strong>

                <p>
                    Lanzamos oficialmente nuestra página de apoyo ❤️
                </p>
            </div>

        </div>

        <!-- Redes -->
        <div class="socials">

            <a href="https://www.tiktok.com/@churonini" target="_blank">
                <i class="fab fa-tiktok"></i>
            </a>

            <a href="https://instagram.com/cristianarroyot" target="_blank">
                <i class="fab fa-instagram"></i>
            </a>

            <a href="https://youtube.com/@churonini" target="_blank">
                <i class="fab fa-youtube"></i>
            </a>

        </div>

    </div>

    <footer>
        Página oficial de apoyo a Churonini · Gracias por formar parte 💖
    </footer>

</div>

<!-- PAYPAL -->
<script>
paypal.HostedButtons({
    hostedButtonId: "N4TKCWT46D6WJ",
}).render("#paypal-container-N4TKCWT46D6WJ");
</script>

<!-- Barra dinámica -->
<script>

const raisedSpan = document.getElementById('raisedAmount');
const progressFill = document.getElementById('progressFill');

let currentRaised = 680;
const goal = 1000;

let percent = (currentRaised / goal) * 100;

raisedSpan.innerText = `$${currentRaised}`;
progressFill.style.width = `${Math.min(percent,100)}%`;

</script>

</body>
</html>
